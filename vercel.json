{
  "version": 2,
  "builds": [
    {
      "src": "server/src/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "client/dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "/server/src/index.js"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/server/uploads/$1"
    },
    {
      "source": "/((?!api|uploads).*)",
      "destination": "/client/dist/index.html"
    }
  ]
}
